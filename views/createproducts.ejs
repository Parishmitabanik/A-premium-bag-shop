<%- include('./partials/header') %>

<% if(success && success.length > 0){ %>
    <div class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-blue-500">
        <span class="inline-block mt-1 mb-1 text-white"><%= success %></span>
    </div>
<% } %>

<div class="min-h-screen flex flex-col">
    <div class="container px-4 md:px-10 py-10 md:py-20 flex flex-col md:flex-row flex-grow gap-6">

        <!-- Sidebar -->
        <div class="w-full md:w-[25%] flex flex-row md:flex-col items-start gap-4 md:gap-2">
            <a class="block w-fit font-medium hover:underline" href="/owners/allproducts">All Products</a>
            <a class="block w-fit font-medium hover:underline" href="/owners/admin">Create New Product</a>
            <a class="block w-fit text-red-500 hover:underline" href="/owners/logout">Logout</a>
        </div>

        <!-- Main Form -->
        <main class="w-full md:w-3/4 bg-white p-6 md:p-8 shadow">
            <h2 class="text-xl font-bold mb-4">Create New Product</h2>
            <form autocomplete="off" action="/products/create" method="post" enctype="multipart/form-data">

                <div class="mb-6">
                    <h3 class="text-lg font-semibold mb-2">Product Details</h3>
                    <div class="mb-4">
                        <label class="block mb-2 font-medium">Product Image</label>
                        <input name="image" type="file" class="py-2 px-4 rounded w-full">
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <input name="name" type="text" placeholder="Product Name"
                            class="border p-2 rounded w-full">
                        <input name="price" type="number" placeholder="Product Price"
                            class="border p-2 rounded w-full">
                        <input name="discount" type="number" placeholder="Discount % (e.g. 25)"
                            class="border p-2 rounded w-full">
                    </div>
                </div>

                <div class="mb-6">
                    <h3 class="text-lg font-semibold mb-2">Panel Details</h3>
                    <p class="text-sm text-gray-400 mb-3">Enter valid CSS colors e.g.
                        <span class="font-mono">#f5cba7</span> or <span class="font-mono">pink</span>
                    </p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm mb-1 text-gray-500">Background Color</label>
                            <input name="bgcolor" type="text" placeholder="#f5cba7"
                                class="border p-2 rounded w-full">
                        </div>
                        <div>
                            <label class="block text-sm mb-1 text-gray-500">Panel Color</label>
                            <input name="panelcolor" type="text" placeholder="#d4ac0d"
                                class="border p-2 rounded w-full">
                        </div>
                        <div>
                            <label class="block text-sm mb-1 text-gray-500">Text Color</label>
                            <input name="textcolor" type="text" placeholder="#ffffff"
                                class="border p-2 rounded w-full">
                        </div>
                    </div>
                </div>

                <input class="px-5 py-2 rounded mt-3 bg-blue-500 text-white cursor-pointer hover:bg-blue-600 w-full sm:w-auto"
                    type="submit" value="Create New Product">
            </form>
        </main>
    </div>
</div>

<%- include('./partials/footer') %>
