<%- include('./partials/header') %>

<div class="w-full min-h-screen px-4 md:px-20 py-10">

    <!-- Back Button -->
    <a href="/shop" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:underline mb-8 block">
        ← Back to Shop
    </a>

    <div class="flex flex-col md:flex-row gap-10 items-start">

        <!-- Left: Product Image -->
        <div class="w-full md:w-[45%]">
            <div class="w-full h-72 sm:h-96 md:h-[28rem] flex items-center justify-center rounded-2xl bg-[<%= product.bgcolor %>]">
                <img class="h-[16rem] sm:h-[22rem] md:h-[26rem] object-contain"
                     src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                     alt="<%= product.name %>">
            </div>
        </div>

        <!-- Right: Product Info -->
        <div class="w-full md:w-[55%] flex flex-col gap-5">

            <!-- Name -->
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-800"><%= product.name %></h1>

            <!-- Price Section -->
            <div class="flex items-center gap-4 flex-wrap">
                <% let discountedPrice = product.price - (product.discount / 100) * product.price; %>
                <span class="text-3xl font-bold text-gray-900">₹ <%= discountedPrice.toFixed(0) %></span>
                <% if(product.discount > 0){ %>
                    <span class="text-lg text-gray-400 line-through">₹ <%= product.price %></span>
                    <span class="px-3 py-1 text-sm rounded-full bg-red-100 text-red-600 font-semibold">
                        <%= product.discount %>% OFF
                    </span>
                <% } %>
            </div>

            <% if(product.discount > 0){ %>
                <p class="text-green-600 text-sm font-medium">
                    🎉 You save ₹ <%= (product.price - discountedPrice).toFixed(0) %> on this product!
                </p>
            <% } %>

            <!-- Divider -->
            <div class="w-full h-[1px] bg-gray-200"></div>

            <!-- Product Details -->
            <div class="flex flex-col gap-3">
                <h3 class="text-lg font-semibold text-gray-700">Product Details</h3>
                <div class="grid grid-cols-2 gap-3 text-sm">
                    <div class="bg-gray-50 rounded-lg p-3">
                        <p class="text-gray-400 text-xs mb-1">Category</p>
                        <p class="font-medium">Premium Bag</p>
                    </div>
                    <div class="bg-gray-50 rounded-lg p-3">
                        <p class="text-gray-400 text-xs mb-1">MRP</p>
                        <p class="font-medium">₹ <%= product.price %></p>
                    </div>
                    <div class="bg-gray-50 rounded-lg p-3">
                        <p class="text-gray-400 text-xs mb-1">Discount</p>
                        <p class="font-medium"><%= product.discount > 0 ? product.discount + '%' : 'No discount' %></p>
                    </div>
                    <div class="bg-gray-50 rounded-lg p-3">
                        <p class="text-gray-400 text-xs mb-1">Availability</p>
                        <p class="font-medium text-green-600">In Stock</p>
                    </div>
                </div>
            </div>

            <!-- Divider -->
            <div class="w-full h-[1px] bg-gray-200"></div>

            <!-- Delivery Info -->
            <div class="flex flex-col gap-2 text-sm text-gray-600">
                <div class="flex items-center gap-2">
                    <i class="ri-truck-line text-orange-500 text-lg"></i>
                    <span>Free delivery on all orders</span>
                </div>
                <div class="flex items-center gap-2">
                    <i class="ri-shield-check-line text-green-500 text-lg"></i>
                    <span>Secure & trusted checkout</span>
                </div>
                <div class="flex items-center gap-2">
                    <i class="ri-refresh-line text-blue-500 text-lg"></i>
                    <span>Easy returns & exchanges</span>
                </div>
            </div>

            <!-- Add to Cart Button -->
            <a href="/addtocart/<%= product._id %>"
               class="mt-2 w-full block text-center py-4 bg-blue-500 hover:bg-blue-600 text-white text-lg font-semibold rounded-xl transition">
                🛍 Add to Cart
            </a>

            <a href="/cart"
               class="w-full block text-center py-4 bg-orange-500 hover:bg-orange-600 text-white text-lg font-semibold rounded-xl transition">
                Go to Cart →
            </a>

            <!-- Reviews Section -->
            <div class="w-full mt-16">
                <div class="w-full h-[1px] bg-gray-200 mb-8"></div>
                <h3 class="text-xl font-semibold text-gray-800 mb-6">
                    Customer Reviews
                    <% let avgRating = product.reviews && product.reviews.length > 0
                        ? (product.reviews.reduce((a,r) => a + r.rating, 0) / product.reviews.length).toFixed(1)
                        : null %>
                    <% if(avgRating){ %>
                        <span class="ml-3 text-base font-normal text-gray-500">
                            <% for(let i=1; i<=5; i++){ %>
                                <i class="ri-star-<%= i <= Math.round(avgRating) ? 'fill text-yellow-400' : 'line text-gray-300' %>"></i>
                            <% } %>
                            <%= avgRating %> (<%= product.reviews.length %> review<%= product.reviews.length !== 1 ? 's' : '' %>)
                        </span>
                    <% } %>
                </h3>

                <% if(!product.reviews || product.reviews.length === 0){ %>
                    <div class="bg-gray-50 rounded-xl p-8 text-center text-gray-400">
                        <i class="ri-chat-3-line text-4xl mb-2 block"></i>
                        <p>No reviews yet. Be the first to review this product!</p>
                    </div>
                <% } else { %>
                    <div class="flex flex-col gap-4">
                    <% product.reviews.slice().reverse().forEach(function(review){ %>
                        <div class="bg-gray-50 rounded-xl p-4 flex flex-col gap-1">
                            <div class="flex items-center justify-between flex-wrap gap-2">
                                <p class="font-semibold text-sm text-gray-800"><%= review.username %></p>
                                <p class="text-xs text-gray-400"><%= new Date(review.reviewedAt).toDateString() %></p>
                            </div>
                            <div class="flex items-center gap-1">
                                <% for(let i=1; i<=5; i++){ %>
                                    <i class="ri-star-<%= i <= review.rating ? 'fill text-yellow-400' : 'line text-gray-300' %> text-sm"></i>
                                <% } %>
                                <span class="text-xs text-gray-500 ml-1"><%= review.rating %>/5</span>
                            </div>
                            <p class="text-sm text-gray-600 italic">"<%= review.comment %>"</p>
                        </div>
                    <% }) %>
                    </div>
                <% } %>
            </div>

        </div>
    </div>
</div>

<%- include('./partials/footer') %>
