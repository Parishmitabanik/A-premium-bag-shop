<%- include('./partials/header') %>

<% if(success && success.length>0){ %>
    <div class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-blue-500">
        <span class="inline-block mt-1 mb-1 text-white"><%= success %></span>
    </div>
<% } %>

<div class="w-full min-h-screen flex flex-col md:flex-row items-start px-4 md:px-20 py-10">

    <!-- Sidebar -->
    <div class="w-full md:w-[25%] flex flex-col items-start md:sticky md:top-20 mb-8 md:mb-0">
        <div class="flex items-center gap-2 flex-wrap">
            <h3>sort by</h3>
            <select
                class="border-[1px] px-2 py-1"
                onchange="window.location.href='/shop?sortby=' + this.value + '&filter=<%= filter %>'">
                <option value="popular"    <%= sortby === 'popular'    ? 'selected' : '' %>>Popular</option>
                <option value="newest"     <%= sortby === 'newest'     ? 'selected' : '' %>>Newest</option>
                <option value="price_asc"  <%= sortby === 'price_asc'  ? 'selected' : '' %>>Price: Low to High</option>
                <option value="price_desc" <%= sortby === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
            </select>
        </div>

        <div class="flex flex-row md:flex-col gap-4 md:gap-0 mt-6 md:mt-20">
            <a class="block w-fit mb-2 font-medium hover:underline"
            href="/shop?sortby=newest&filter=new">New Collection</a>
            <a class="block w-fit mb-2 font-medium hover:underline"
            href="/shop?sortby=<%= sortby %>&filter=">All Products</a>
            <a class="block w-fit mb-2 font-medium hover:underline"
            href="/shop?sortby=<%= sortby %>&filter=discounted">Discounted Products</a>
        </div>

        <div class="mt-6 md:mt-32">
            <p class="block w-fit mb-2 font-semibold">Filter by :</p>
            <a class="block w-fit mb-2 hover:underline"
               href="/shop?sortby=<%= sortby %>&filter=">Availability</a>
            <a class="block w-fit mb-2 hover:underline"
               href="/shop?sortby=<%= sortby %>&filter=discounted">Discount</a>
        </div>
    </div>

    <!-- Products Grid -->
    <div class="w-full md:w-[75%] grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <% products.forEach(function(product){ %>
            <div class="w-full">
                <div class="w-full h-40 sm:h-52 flex items-center justify-center bg-[<%= product.bgcolor %>]">
                    <img class="h-[9rem] sm:h-[12rem] object-contain"
                         src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                         alt="">
                </div>
                <div class="flex justify-between bg-[<%= product.panelcolor %>] items-center px-3 py-3 text-[<%= product.textcolor %>]">
                    <div class="flex-1 min-w-0 mr-2">
                        <h3 class="text-sm font-medium truncate"><%= product.name %></h3>
                        <div class="flex items-center gap-1 flex-wrap">
                            <h4 class="text-sm">₹ <%= product.price %></h4>
                            <% if(product.discount > 0){ %>
                                <span class="px-1.5 py-0.5 text-xs rounded bg-red-200 text-red-700">
                                    -<%= product.discount %>%
                                </span>
                            <% } %>
                        </div>
                    </div>
                    <a class="w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-full bg-white"
                       href="/addtocart/<%= product._id %>">
                        <i class="ri-add-line text-black"></i>
                    </a>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<%- include('./partials/footer') %>
