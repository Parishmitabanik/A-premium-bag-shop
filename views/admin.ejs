<%- include('./partials/header') %>

<% if(success && success.length > 0){ %>
    <div class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-blue-500">
        <span class="inline-block mt-1 mb-1 text-white"><%= success %></span>
    </div>
<% } %>

<div class="min-h-screen flex flex-col">
    <div class="container px-4 md:px-10 py-10 md:py-20 flex flex-col md:flex-row flex-grow gap-6">

        <!-- Sidebar -->
        <div class="w-full md:w-[25%] flex flex-row md:flex-col items-start gap-4 md:gap-2">
            <a class="block w-fit font-medium hover:underline" href="/owners/admin">Create New Product</a>
            <a class="block w-fit text-red-500 hover:underline" href="/owners/logout">Logout</a>
        </div>

        <!-- Products List -->
        <main class="w-full md:w-3/4 bg-white p-6 md:p-8 shadow">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold">All Products (<%= products.length %>)</h2>
                <a href="/owners/admin" class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 text-sm">
                    + Add New
                </a>
            </div>

            <% if(products.length === 0){ %>
                <p class="text-gray-400 text-center mt-20">No products yet. <a href="/owners/admin" class="text-blue-500 hover:underline">Create one.</a></p>
            <% } else { %>
                <div class="flex flex-col gap-4">
                    <% products.forEach(function(product){ %>
                        <div class="flex items-center justify-between border rounded-lg p-3 md:p-4 hover:shadow transition flex-wrap gap-3">
                            <div class="flex items-center gap-3 md:gap-4">
                                <div class="w-14 h-14 md:w-16 md:h-16 rounded flex items-center justify-center overflow-hidden flex-shrink-0"
                                     style="background-color: <%= product.bgcolor %>">
                                    <img class="h-full object-contain"
                                         src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                                         alt="<%= product.name %>">
                                </div>
                                <div>
                                    <h3 class="font-semibold text-base md:text-lg"><%= product.name %></h3>
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="text-gray-600">₹ <%= product.price %></span>
                                        <% if(product.discount > 0){ %>
                                            <span class="px-2 py-0.5 text-xs rounded bg-red-100 text-red-600">
                                                -<%= product.discount %>% off
                                            </span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="flex gap-2 md:gap-3">
                                <a href="/owners/editproduct/<%= product._id %>"
                                class="px-3 py-1 text-sm bg-blue-100 text-blue-600 rounded hover:bg-blue-200">
                                    Edit
                                </a>
                                <a href="/owners/deleteproduct/<%= product._id %>"
                                onclick="return confirm('Delete this product?')"
                                class="px-3 py-1 text-sm bg-red-100 text-red-600 rounded hover:bg-red-200">
                                    Delete
                                </a>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </main>
    </div>
</div>

<%- include('./partials/footer') %>
