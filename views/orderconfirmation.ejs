<%- include('./partials/header') %>

<div class="w-full min-h-screen flex items-center justify-center px-4 md:px-20 py-10 md:py-16">
    <div class="bg-white shadow-lg rounded-2xl p-8 md:p-12 max-w-xl w-full text-center">

        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="ri-checkbox-circle-fill text-green-500 text-5xl"></i>
        </div>

        <h2 class="text-2xl md:text-3xl font-bold text-green-600 mb-2">Order Placed!</h2>
        <p class="text-gray-500 mb-6">Thank you, <span class="font-semibold text-black"><%= username %></span>. Your order has been confirmed.</p>

        <div class="bg-zinc-50 rounded-lg p-4 md:p-5 text-left mb-6 flex flex-col gap-3">
            <div class="flex justify-between flex-wrap gap-1">
                <span class="text-gray-500">Order ID</span>
                <span class="font-mono text-sm font-semibold"><%= orderId %></span>
            </div>
            <div class="flex justify-between flex-wrap gap-1">
                <span class="text-gray-500">Payment Mode</span>
                <span class="font-medium capitalize"><%= paymentmode %></span>
            </div>
            <div class="flex justify-between flex-wrap gap-1">
                <span class="text-gray-500">Delivering To</span>
                <span class="font-medium text-right max-w-[60%]"><%= address %>, <%= city %>, <%= state %> - <%= pincode %></span>
            </div>
            <div class="flex justify-between flex-wrap gap-1">
                <span class="text-gray-500">
                    <%= paymentmode === 'cod' ? 'Amount Due on Delivery' : 'Total Paid' %>
                </span>
                <span class="font-bold <%= paymentmode === 'cod' ? 'text-orange-500' : 'text-green-600' %>">
                    ₹ <%= bill.toFixed(0) %>
                </span>
            </div>
            <div class="flex justify-between flex-wrap gap-1">
                <span class="text-gray-500">Estimated Delivery</span>
                <span class="font-semibold text-orange-500"><%= deliveryDate %></span>
            </div>
        </div>

        <a href="/shop"
           class="block w-full py-3 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-lg">
            Continue Shopping
        </a>
    </div>
</div>

<%- include('./partials/footer') %>
