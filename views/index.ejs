<%- include('./partials/header') %>

<% if(error && error.length > 0){ %>
    <div class="fixed top-5 left-1/2 -translate-x-1/2 z-50 p-3 px-6 rounded-md bg-red-500 shadow-lg">
        <span class="text-white font-medium"><%= error %></span>
    </div>
<% } %>

<% if(success && success.length > 0){ %>
    <div class="fixed top-5 left-1/2 -translate-x-1/2 z-50 p-3 px-6 rounded-md bg-green-500 shadow-lg">
        <span class="text-white font-medium"><%= success %></span>
    </div>
<% } %>

<div class="w-full min-h-screen flex flex-col items-center justify-center">

    <!-- Role Chooser -->
    <div id="role-chooser" class="flex flex-col items-center gap-6">
        <h2 class="text-4xl font-semibold">Welcome to <span class="text-blue-500">Scatch</span></h2>
        <p class="text-gray-500 text-lg">Continue as a buyer or seller?</p>
        <div class="flex gap-6 mt-4">
            <button onclick="showPanel('buyer')"
                class="px-10 py-4 bg-blue-500 text-white text-lg rounded-full hover:bg-blue-600 transition">
                🛍 Buyer
            </button>
            <button onclick="showPanel('seller')"
                class="px-10 py-4 bg-green-500 text-white text-lg rounded-full hover:bg-green-600 transition">
                🏪 Seller
            </button>
        </div>
    </div>

    <!-- BUYER PANEL -->
    <div id="buyer-panel" class="hidden w-full flex">
        <div class="w-1/2 flex items-center justify-center min-h-screen border-r">
            <div class="w-full px-32">
                <button onclick="showPanel('home')" class="text-sm text-gray-400 mb-6 hover:underline">← Back</button>
                <h3 class="text-3xl mb-1">Welcome to <span class="text-blue-400 font-semibold">Scatch</span></h3>
                <h4 class="text-xl text-gray-500 mb-5">Create buyer account</h4>
                <form autocomplete="off" action="/users/register" method="post">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="text" placeholder="Full Name" name="fullname">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="email" placeholder="Email" name="email">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="password" placeholder="Password" name="password">
                    <input class="px-5 rounded-full py-3 mt-2 bg-blue-500 text-white cursor-pointer" type="submit"
                        value="Create Account">
                </form>
            </div>
        </div>
        <div class="w-1/2 flex items-center justify-center min-h-screen">
            <div class="w-full px-32">
                <h4 class="text-2xl mb-5">Login as Buyer</h4>
                <form autocomplete="off" action="/users/login" method="post">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="email" placeholder="Email" name="email">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="password" placeholder="Password" name="password">
                    <input class="px-5 block rounded-full py-3 mt-2 bg-blue-500 text-white cursor-pointer" type="submit"
                        value="Login">
                </form>
            </div>
        </div>
    </div>

    <!-- SELLER PANEL -->
    <div id="seller-panel" class="hidden w-full flex">
        <div class="w-1/2 flex items-center justify-center min-h-screen border-r">
            <div class="w-full px-32">
                <button onclick="showPanel('home')" class="text-sm text-gray-400 mb-6 hover:underline">← Back</button>
                <h3 class="text-3xl mb-1">Register as <span class="text-green-500 font-semibold">Seller</span></h3>
                <h4 class="text-lg text-gray-500 mb-5">Create your seller account</h4>
                <form autocomplete="off" action="/owners/register" method="post">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="text" placeholder="Full Name" name="fullname">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="email" placeholder="Email" name="email">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="password" placeholder="Password" name="password">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="text" placeholder="GSTIN Number" name="gstin">
                    <input class="px-5 rounded-full py-3 mt-2 bg-green-500 text-white cursor-pointer" type="submit"
                        value="Register as Seller">
                </form>
            </div>
        </div>
        <div class="w-1/2 flex items-center justify-center min-h-screen">
            <div class="w-full px-32">
                <h4 class="text-2xl mb-5">Login as Seller</h4>
                <form autocomplete="off" action="/owners/login" method="post">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="email" placeholder="Seller Email" name="email">
                    <input class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                        type="password" placeholder="Password" name="password">
                    <input class="px-5 block rounded-full py-3 mt-2 bg-green-500 text-white cursor-pointer" type="submit"
                        value="Login as Seller">
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function showPanel(role) {
        document.getElementById('role-chooser').classList.add('hidden');
        document.getElementById('buyer-panel').classList.add('hidden');
        document.getElementById('seller-panel').classList.add('hidden');

        if (role === 'home') {
            document.getElementById('role-chooser').classList.remove('hidden');
        } else if (role === 'buyer') {
            document.getElementById('buyer-panel').classList.remove('hidden');
        } else if (role === 'seller') {
            document.getElementById('seller-panel').classList.remove('hidden');
        }
    }
    
    // Auto-open correct panel if redirected back with an error
    <% if(typeof showPanel !== 'undefined' && showPanel){ %>
        showPanel('<%= showPanel %>');
    <% } %>
</script>

<%- include('./partials/footer') %>